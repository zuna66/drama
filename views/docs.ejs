<script>

const envPublicUrl = "<%= publicUrl %>"; 
const cleanPublicUrl = envPublicUrl ? envPublicUrl.replace(/\/$/, '') : '';
const globalBaseUrl = cleanPublicUrl || window.location.origin;

document.getElementById('baseUrlText').innerText = globalBaseUrl;

let currentLang = 'in';
const languageMap = [
    { code: 'in', name: '🇮🇩 Indonesia' },
    { code: 'en', name: '🇺🇸 English' },
    { code: 'ja', name: '🇯🇵 日本語' },
    { code: 'zhHans', name: '🇨🇳 简体中文' },
    { code: 'zh', name: '🇹🇼 繁體中文' },
    { code: 'es', name: '🇪🇸 Español' },
    { code: 'de', name: '🇩🇪 Deutsch' },
    { code: 'fr', name: '🇫🇷 Français' },
    { code: 'pt', name: '🇵🇹 Português' },
    { code: 'ar', name: '🇸🇦 العربية' },
    { code: 'th', name: '🇹🇭 ไทย' },
    { code: 'tl', name: '🇵🇭 Tagalog' }
];

function copyText(text, btn) {
    navigator.clipboard.writeText(text).then(() => {
        const originalContent = btn.innerHTML;
        btn.innerHTML = '<i class="fa-solid fa-check text-green-400"></i>';
        setTimeout(() => {
            btn.innerHTML = originalContent;
        }, 1500);
    }).catch(err => {
        console.error('Failed to copy: ', err);
        alert('Gagal menyalin teks');
    });
}

function copyElementText(elementId, btn) {
    const text = document.getElementById(elementId).innerText;
    copyText(text, btn);
} 

function initializeLanguageSelector() {
    const selector = document.getElementById('langOptionsContainer'); 
    const currentLangDisplay = document.getElementById('currentLang'); 
    const langBtn = document.getElementById("langDropdownBtn");
    const langMenu = document.getElementById("langMenu");
    const defaultLang = 'in';

    languageMap.forEach(lang => {
        const button = document.createElement('button');
        button.className = 'block w-full text-left px-4 py-2 text-xs text-gray-300 hover:bg-blue-600 hover:text-white transition';
        button.setAttribute('data-lang', lang.code);
        button.textContent = lang.name;
        
        button.addEventListener("click", () => {
            currentLang = lang.code;
            currentLangDisplay.innerText = lang.name; 
            langMenu.classList.add("hidden");
        });
        
        selector.appendChild(button);
    });

    const defaultLangItem = languageMap.find(l => l.code === defaultLang);
    if (defaultLangItem) {
        currentLang = defaultLang;
        currentLangDisplay.innerText = defaultLangItem.name;
    }

    langBtn.addEventListener("click", () => langMenu.classList.toggle("hidden"));

    document.addEventListener('click', function(event) {
        if (!langBtn.contains(event.target) && !langMenu.contains(event.target)) {
            langMenu.classList.add('hidden');
        }
    });
}

function toggleAccordion(endpointId) {
    const content = document.getElementById(`content-${endpointId}`);
    const arrow = document.getElementById(`arrow-${endpointId}`);

    if (content.classList.contains('hidden')) {
        content.classList.remove('hidden');
        arrow.classList.add('rotate-90');
    } else {
        content.classList.add('hidden');
        arrow.classList.remove('rotate-90');
    }
}

function syntaxHighlight(json) {
    if (typeof json != 'string') {
         json = JSON.stringify(json, undefined, 2);
    }
    json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    return json.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (match) {
        var cls = 'json-number';
        if (/^"/.test(match)) {
            if (/:$/.test(match)) {
                cls = 'json-key';
            } else {
                cls = 'json-string';
            }
        } else if (/true|false/.test(match)) {
            cls = 'json-boolean';
        } else if (/null/.test(match)) {
            cls = 'json-null';
        }
        return '<span class="' + cls + '">' + match + '</span>';
    });
}

function displayResult(id, data, error, responseTimeMs, url) {
  const headerDiv = document.getElementById('result-header-' + id);
  const contentDiv = document.getElementById('result-content-' + id);
  headerDiv.classList.remove('hidden');
  contentDiv.classList.remove('hidden');
  const urlBoxHtml = url ? `
    <div class="mt-3 p-3 bg-black/40 rounded border border-gray-700 flex flex-col sm:flex-row sm:items-center justify-between gap-3 group hover:border-blue-500/50 transition">
        <div class="flex flex-col gap-1 overflow-hidden w-full">
            <span class="text-[9px] uppercase text-gray-500 font-bold tracking-wider">Request URL</span>
            <code class="text-[11px] text-blue-400 font-mono break-all leading-tight">${url}</code>
        </div>
        
        <div class="flex gap-3 shrink-0 self-end sm:self-auto">
            <button onclick="copyText('${url}', this)" 
                class="h-8 w-8 flex items-center justify-center bg-gray-800 hover:bg-gray-700 rounded text-gray-400 hover:text-white border border-gray-700 transition" title="Copy Full URL">
                <i class="fa-regular fa-copy text-xs"></i>
            </button>
            <a href="${url}" target="_blank" 
                class="h-8 w-8 flex items-center justify-center bg-gray-800 hover:bg-gray-700 rounded text-gray-400 hover:text-blue-400 border border-gray-700 transition" title="Open in New Tab">
                <i class="fa-solid fa-arrow-up-right-from-square text-[10px]"></i>
            </a>
        </div>
    </div>` : '';

  if (error) {
    headerDiv.innerHTML = `
        <div class="flex justify-between items-center text-red-400 font-bold mb-1">
            <span>❌ GAGAL</span> 
            <span class="text-[10px] font-mono text-gray-500">${responseTimeMs.toFixed(0)}ms</span>
        </div>
        ${urlBoxHtml}
    `;
    contentDiv.innerHTML = syntaxHighlight({ error: error });
  } else {
    headerDiv.innerHTML = `
        <div>
            <div class="flex justify-between items-center text-green-400 font-bold">
                <div class="flex items-center gap-3">
                    <span>✅ SUKSES</span>
                    <button onclick="copyElementText('result-content-${id}', this)" 
                        class="text-[10px] bg-gray-800 hover:bg-gray-700 border border-gray-700 hover:border-gray-600 text-gray-300 px-2 py-1 rounded transition flex items-center gap-1.5" title="Copy JSON Result">
                        <i class="fa-regular fa-copy"></i> Copy JSON
                    </button>
                </div>
                <span class="text-[10px] font-mono text-gray-500">${responseTimeMs.toFixed(0)}ms</span>
            </div>
            ${urlBoxHtml}
        </div>`;
    contentDiv.innerHTML = syntaxHighlight(data);
  }
}


async function testGetEndpoint(endpointId, urlInput, defaultParams = {}) {
    const btn = document.getElementById(`btn-${endpointId}`);
    if(btn) btn.disabled = true;
    const headerDiv = document.getElementById('result-header-' + endpointId);
    const contentDiv = document.getElementById('result-content-' + endpointId);
    headerDiv.classList.remove("hidden");
    contentDiv.classList.add("hidden");
    headerDiv.innerHTML = '<span class="text-blue-400 animate-pulse"><i class="fa-solid fa-spinner fa-spin mr-2"></i>Memuat...</span>';
    
    const startTime = performance.now();
    try {
        const baseUrl = urlInput.startsWith('http') ?
            urlInput : globalBaseUrl + urlInput;
        const urlObj = new URL(baseUrl);
        for (const [key, defaultValue] of Object.entries(defaultParams)) {
            if (urlObj.pathname.includes(`:${key}`)) {
                urlObj.pathname = urlObj.pathname.replace(`:${key}`, defaultValue);
            } 
            else if (defaultValue !== '') {
                urlObj.searchParams.set(key, defaultValue);
            }
        }
        
        if (!urlObj.searchParams.has('lang')) {
            urlObj.searchParams.set('lang', currentLang);
        }
        const finalUrl = urlObj.toString();
        const response = await fetch(finalUrl);
        const data = await response.json();
        const endTime = performance.now(); 
        if (!response.ok) throw new Error(`Status ${response.status} ${response.statusText}`);
        displayResult(endpointId, data, null, endTime - startTime, finalUrl);
    } catch (error) {
        const fallbackUrl = globalBaseUrl + urlInput;
        displayResult(endpointId, null, error.message, performance.now() - startTime, fallbackUrl);
    } finally {
        if(btn) btn.disabled = false;
    }
}

document.addEventListener('DOMContentLoaded', initializeLanguageSelector);
</script>

