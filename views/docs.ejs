                <div id="result-header-search-suggest" class="mt-4 hidden p-3 rounded-t bg-gray-800 border border-gray-700 text-xs"></div>
                <pre id="result-content-search-suggest" class="hidden p-3 rounded-b bg-gray-900 border border-t-0 border-gray-700 text-xs max-h-[300px] overflow-y-auto font-mono whitespace-pre-wrap break-all"></pre>
            </div>
        </div>
       
        <div class="rounded-lg border border-yellow-900/30 bg-gray-900 overflow-hidden transition-all hover:border-yellow-700 shadow-[0_0_15px_rgba(234,179,8,0.1)]">
            <div class="flex items-center justify-between p-4 cursor-pointer hover:bg-yellow-900/10 transition" onclick="toggleAccordion('vip')">
                <div class="flex items-center gap-3">
                    <span class="px-2.5 py-0.5 text-[10px] font-bold rounded bg-yellow-600/20 text-yellow-400 border border-yellow-600/30">GET</span>
                    <h3 class="font-semibold text-sm text-yellow-400">Vip Channel</h3>
                    <code class="font-mono text-gray-500 text-xs hidden sm:block">/api/vip</code>
                </div>
                <i id="arrow-vip" class="fa-solid fa-chevron-right text-gray-500 text-sm transition-transform duration-200"></i>
            </div>
            
            <div id="content-vip" class="hidden border-t border-gray-800 bg-black/20 p-4">
                <p class="mb-3 text-xs text-gray-400">Mengambil daftar rekomendasi drama dari channel VIP/Theater.</p>
                <button id="btn-vip" onclick="testGetEndpoint('vip', '/api/vip', {})" 
                    class="bg-yellow-600 hover:bg-yellow-700 text-black px-4 py-2 rounded text-xs font-bold flex items-center gap-2 transition">
                    <i class="fa-solid fa-crown text-[10px]"></i> Ambil Data VIP
